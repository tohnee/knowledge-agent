# ── Neo4j (KnowledgeStore production backend) ──
NEO4J_URI=bolt://wka-neo4j:7687
NEO4J_PASSWORD=change-me

# ── Local DeepSeek / GLM (vLLM / Ollama, OpenAI-compatible) ──
DEEPSEEK_LOCAL_URL=http://vllm:8000/v1
DEEPSEEK_MODEL=deepseek-v3
GLM_LOCAL_URL=http://ollama:11434/v1
GLM_MODEL=glm-4

# ── Export-control egress gate ──
LOCAL_LLM_HOSTS=vllm,ollama,wka-vllm,wka-ollama   # controlled content may ONLY hit these hosts
CLAUDE_CODE_LOCAL_ONLY=1                           # Claude Code must be local-only for controlled docs

# ── API auth and CORS ──
# dev keeps the local Role header for tests/demos; production should use jwt + a real secret.
WKA_AUTH_MODE=dev
WKA_ALLOW_ROLE_HEADER=1
WKA_JWT_SECRET=change-me-dev-secret
WKA_CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# ── Optional OPA / Vault integrations ──
WKA_OPA_URL=
WKA_OPA_TIMEOUT=2
WKA_VAULT_URL=
WKA_VAULT_TOKEN=
WKA_VAULT_TIMEOUT=2
